# Copy this file to .env.local and fill in your values.
# .env.local is gitignored. On Vercel, set these in Project Settings -> Environment Variables.

# A GitHub personal access token with write access to the data repo.
# Fine-grained token scoped to a single repo with "Contents: Read and write" is safest.
GITHUB_TOKEN=

# Where the JSON data file lives.
GITHUB_REPO_OWNER=BereaCollege-IE
GITHUB_REPO_NAME=Project-Dashboard
GITHUB_DATA_PATH=data/projects.json
GITHUB_BRANCH=main

# Anthropic API key for the task assistant chat. Server-side only.
ANTHROPIC_API_KEY=
# Optional: which model the assistant uses. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: daily deadline reminder email (Gmail SMTP). Leave blank to disable.
# Set the recipient under Settings in the app, and these credentials here.
AUTH_EMAIL_USER=
AUTH_EMAIL_PASS=
AUTH_EMAIL_FROM=
# Shared secret that protects the cron endpoint. Vercel sends it as a Bearer token.
CRON_SECRET=
