# Copy this file to .env.local and fill in your values.
# .env.local is gitignored. On Vercel, set these in Project Settings -> Environment Variables.

# A GitHub personal access token with write access to the data repo.
# Fine-grained token scoped to a single repo with "Contents: Read and write" is safest.
GITHUB_TOKEN=

# Where the JSON data file lives.
GITHUB_REPO_OWNER=BereaCollege-IE
GITHUB_REPO_NAME=Project-Dashboard
GITHUB_DATA_PATH=data/projects.json
GITHUB_BRANCH=main
